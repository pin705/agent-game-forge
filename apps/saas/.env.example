# =============================================================================
# Footage SaaS — environment variables (P0)
# Copy to `.env.local` and fill with your Supabase project values.
# Never commit real secrets. `.env.local` is gitignored.
# =============================================================================

# Supabase project URL, e.g. https://abcdefgh.supabase.co
# (Supabase dashboard → Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe for the browser; RLS enforces access).
# (Dashboard → Project Settings → API → Project API keys → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service-role key (SERVER ONLY — bypasses RLS). Used by trusted
# server code (e.g. SePay webhook in P3). Never expose to the browser.
# (Dashboard → Project Settings → API → Project API keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
