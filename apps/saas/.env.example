# =============================================================================
# Footage SaaS — environment variables (P0)
# Copy to `.env.local` and fill with your Supabase project values.
# Never commit real secrets. `.env.local` is gitignored.
# =============================================================================

# Supabase project URL, e.g. https://abcdefgh.supabase.co
# (Supabase dashboard → Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe for the browser; RLS enforces access).
# (Dashboard → Project Settings → API → Project API keys → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key (SERVER ONLY — bypasses RLS). Used by trusted
# server code (e.g. SePay webhook in P3). Never expose to the browser.
# (Dashboard → Project Settings → API → Project API keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# P1 — Agent run (the hard core). Each adapter falls back to a LOCAL driver
# when its prod env is absent, so the whole loop runs with ZERO accounts.
# =============================================================================

# --- Model (lib/agent) -------------------------------------------------------
# When DEEPSEEK_API_KEY is set → real DeepSeek (OpenAI-compatible) model.
# When ABSENT → deterministic MockModel (drives a scripted mini-build offline).
DEEPSEEK_API_KEY=
# OpenAI-compatible base URL (default: https://api.deepseek.com).
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Model id (default: deepseek-chat). This is the DEFAULT/fallback model id used
# when a run doesn't request one. P5 multi-model: the build composer lets the
# user pick a model per run from lib/agent/catalog.ts — today the working
# (enabled) tiers are `deepseek-chat` + `deepseek-v4-flash`; `premium-claude` /
# `premium-gpt` are shown DISABLED ("coming soon") and rejected by /api/runs
# until their routes ship. The chosen id is recorded on the run and priced
# per-tier by lib/billing/pricing.ts (no new env needed for selection).
DEEPSEEK_MODEL=deepseek-v4-flash
# Optional: cap on agent loop steps (default 24).
AGENT_MAX_STEPS=24

# --- Sandbox (lib/sandbox) ---------------------------------------------------
# When E2B_API_KEY is set → E2BSandbox (real isolation, @e2b/code-interpreter).
# When ABSENT → LocalSandbox (temp dir + child_process; dev only, no isolation).
# (A bad/failing key cleanly falls back to LocalSandbox with a logged warning.)
E2B_API_KEY=

# --- Storage (lib/storage) ---------------------------------------------------
# When ALL FOUR R2_* are set → R2Storage (Cloudflare R2 via the S3 API).
# When any is absent → LocalStorage (.data/projects/<id>/ on the filesystem).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- Local-driver data dir (optional) ----------------------------------------
# Where LocalStorage + LocalSandbox write. Default: <app>/.data (gitignored).
# OGF_DATA_DIR=

# =============================================================================
# P3 — Payments via SePay (VietQR / bank transfer, VN-first). All EMPTY here —
# fill in `.env.local` to go live; never commit real values. With these absent
# the top-up UI still renders a (simulated) order + QR locally, and the webhook
# authenticates + parses but doesn't persist (no Supabase). See §5.
# =============================================================================

# SePay webhook shared secret. SePay sends `Authorization: Apikey <key>` on each
# webhook POST; we constant-time compare it to this. If UNSET, the webhook fails
# closed (rejects every call). (SePay dashboard → Company → Webhooks → API key.)
SEPAY_WEBHOOK_API_KEY=

# Receiving bank account number the VietQR pays into (the account SePay watches).
SEPAY_BANK_ACCOUNT=

# Bank code recognised by SePay/VietQR, e.g. MBBank, Vietcombank, ACB, TPBank.
# (See SePay's supported-banks list; this is the `bank` query param of the QR.)
SEPAY_BANK_CODE=

# Optional: account holder name, shown in the top-up UI for reassurance.
SEPAY_ACCOUNT_NAME=

# =============================================================================
# P4 — Publish + Share + Remix (the GTM loop). The PRIMARY share path serves a
# published game from our own storage at a public /play/<slug> URL — it needs
# ZERO Cloudflare and works in local-dev. These vars are all OPTIONAL.
# =============================================================================

# Public base URL used to build absolute /play/<slug> share links. In prod set
# this to your deployed origin, e.g. https://studio.example.com. When UNSET we
# fall back to the request origin, then http://localhost:7640 in dev.
NEXT_PUBLIC_SITE_URL=

# Optional secondary publish path — Cloudflare Pages "export" (ported in spirit
# from the old daemon publish flow). Export is a NO-OP unless BOTH of these are
# set; when absent, publishing just returns the /play/<slug> URL. Never commit
# real values. (Cloudflare dashboard → My Profile → API Tokens [Pages: Edit] and
# the Account ID from any zone/overview page.)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
