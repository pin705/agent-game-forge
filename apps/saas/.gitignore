# Next.js
/.next/
/out/
next-env.d.ts

# Dependencies (managed at the monorepo root)
/node_modules/

# Env — never commit real secrets. .env.local is local placeholders only.
.env*.local

# Local-driver data (LocalStorage project files + LocalSandbox workspaces).
# Created at runtime by the dev drivers; never commit.
/.data/

# E2E artifacts (real-browser screenshots + isolated temp data dirs).
/e2e/shots/

# Logs / misc
*.log
.DS_Store
*.tsbuildinfo
